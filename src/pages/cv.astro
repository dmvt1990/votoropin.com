---
// src/pages/cv.astro
import Base from "../layouts/Base.astro";
import { t } from "../i18n";

const USE_REAL_PHOTO = true;
---

<Base title={t.cv.pageTitle} description={t.cv.pageDescription}>

  <section class="container-wide pt-24 pb-20">
    <div class="section-label">{t.cv.sectionLabel}</div>
    <h1 class="display font-normal text-[44px] sm:text-[56px] leading-[1.05] tracking-tighter max-w-[860px] m-0 mb-14">
      {t.cv.h1part1}<em>{t.cv.h1em}</em>{t.cv.h1part2}
    </h1>

    <div class="grid md:grid-cols-[340px_1fr] gap-12 items-start">

      <!-- ── Photo + quick facts ─────────────────────────────── -->
      <div>
        {USE_REAL_PHOTO ? (
          <img
            src="/images/photo.jpg"
            alt={t.cv.photoAlt}
            class="aspect-[3/4] w-full object-cover rounded-sm"
            width="800"
            height="1067"
          />
        ) : (
          <div
            class="aspect-[3/4] rounded-sm relative overflow-hidden"
            style="
              background:
                linear-gradient(135deg, rgba(107,31,46,0.85), rgba(26,26,26,0.7)),
                repeating-linear-gradient(45deg, #2a2a2a 0 2px, #1a1a1a 2px 4px);
            "
            aria-label="Photo placeholder — replace with actual portrait"
          >
            <span class="absolute bottom-5 left-5 font-mono text-[10px] tracking-[0.2em] text-white/50">PHOTO</span>
          </div>
        )}
        <p class="mt-4 text-[12px] text-ink-mute italic leading-relaxed m-0">
          {t.cv.photoCaption1}<br />
          {t.cv.photoCaption2}
        </p>

        <dl class="mt-8 pt-6 border-t border-rule grid grid-cols-1 gap-4 text-[13px]">
          <div class="flex justify-between gap-4">
            <dt class="text-ink-mute uppercase tracking-[0.1em] text-[10px]">{t.cv.quickFacts.locationLabel}</dt>
            <dd class="m-0 text-ink">{t.cv.quickFacts.locationValue}</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-ink-mute uppercase tracking-[0.1em] text-[10px]">{t.cv.quickFacts.mobilityLabel}</dt>
            <dd class="m-0 text-ink">{t.cv.quickFacts.mobilityValue}</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-ink-mute uppercase tracking-[0.1em] text-[10px]">{t.cv.quickFacts.experienceLabel}</dt>
            <dd class="m-0 text-ink">{t.cv.quickFacts.experienceValue}</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-ink-mute uppercase tracking-[0.1em] text-[10px]">{t.cv.quickFacts.designationLabel}</dt>
            <dd class="m-0 text-ink">{t.cv.quickFacts.designationValue}</dd>
          </div>
        </dl>

        <div class="mt-8 pt-6 border-t border-rule text-[13px]">
          <a href="/downloads/votoropin-cv.pdf" class="editorial-link" download>
            {t.cv.downloadCv}
          </a>
        </div>
      </div>

      <!-- ── Main column ─────────────────────────────────────── -->
      <div>

        <!-- Experience -->
        <div class="mb-14">
          <h2 class="font-sans text-[11px] uppercase tracking-[0.18em] text-ink-mute font-medium m-0 mb-6 pb-3 border-b border-rule">
            {t.cv.sections.experience}
          </h2>
          {t.cv.experience.map((e) => (
            <article class="mb-10">
              <div class="font-display text-[22px] font-medium tracking-tight mb-1 leading-snug">
                {e.role}
              </div>
              <div class="text-accent text-[15px] mb-1">{e.company}</div>
              <div class="font-mono text-[12px] text-ink-mute tracking-wide mb-3">
                {e.dates} · {e.location}
              </div>
              <ul class="list-none p-0 m-0">
                {e.bullets.map((b) => (
                  <li class="relative pl-5 mb-2 text-[15px] text-ink-soft leading-relaxed">
                    <span class="absolute left-0 top-0 text-accent">·</span>
                    {b}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>

        <!-- Education -->
        <div class="mb-14">
          <h2 class="font-sans text-[11px] uppercase tracking-[0.18em] text-ink-mute font-medium m-0 mb-6 pb-3 border-b border-rule">
            {t.cv.sections.education}
          </h2>
          {t.cv.education.map((ed) => (
            <article class="mb-6">
              <div class="font-display text-[18px] font-medium tracking-tight mb-1">{ed.degree}</div>
              <div class="text-accent text-[14px] mb-1">{ed.institution}</div>
              <div class="font-mono text-[12px] text-ink-mute tracking-wide">{ed.dates}</div>
            </article>
          ))}
        </div>

        <!-- Credentials -->
        <div class="mb-14">
          <h2 class="font-sans text-[11px] uppercase tracking-[0.18em] text-ink-mute font-medium m-0 mb-6 pb-3 border-b border-rule">
            {t.cv.sections.credentials}
          </h2>
          {t.cv.credentials.map((c) => (
            <article class="mb-6">
              <div class="font-display text-[18px] font-medium mb-1">{c.name}</div>
              <div class="text-[13px] text-ink-soft leading-relaxed">{c.org}</div>
            </article>
          ))}
        </div>

        <!-- Awards -->
        <div class="mb-14">
          <h2 class="font-sans text-[11px] uppercase tracking-[0.18em] text-ink-mute font-medium m-0 mb-6 pb-3 border-b border-rule">
            {t.cv.sections.awards}
          </h2>
          <ul class="list-none p-0 m-0">
            {t.cv.awards.map((a) => (
              <li class="grid grid-cols-[60px_1fr_auto] gap-4 py-3 border-b border-rule items-baseline">
                <span class="font-mono text-[12px] text-accent">{a.year}</span>
                <span class="font-display text-[16px] font-medium">{a.name}</span>
                <span class="text-[13px] text-ink-mute">{a.location}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Capabilities -->
        <div class="mb-14">
          <h2 class="font-sans text-[11px] uppercase tracking-[0.18em] text-ink-mute font-medium m-0 mb-6 pb-3 border-b border-rule">
            {t.cv.sections.capabilities}
          </h2>
          <p class="text-ink-soft text-[15px] leading-[1.7] m-0">
            {t.cv.capabilitiesText}
          </p>
        </div>

        <!-- Languages -->
        <div class="mb-14">
          <h2 class="font-sans text-[11px] uppercase tracking-[0.18em] text-ink-mute font-medium m-0 mb-6 pb-3 border-b border-rule">
            {t.cv.sections.languages}
          </h2>
          <p class="text-ink-soft text-[15px] leading-relaxed m-0">{t.cv.languages}</p>
        </div>

        <!-- Open-to-mandates block -->
        <div class="mt-16 p-8 bg-bg-sunken border-l-2 border-accent">
          <h3 class="font-sans text-[11px] uppercase tracking-[0.18em] text-accent font-medium m-0 mb-3">
            {t.cv.openToConversations.label}
          </h3>
          <p class="text-[16px] leading-relaxed text-ink m-0 mb-4">
            {t.cv.openToConversations.p}
          </p>
          <p class="text-[14px] text-ink-soft m-0">
            <a href="mailto:d@votoropin.com" class="editorial-link">d@votoropin.com</a>
            ·
            <a href="https://www.linkedin.com/in/dmitrii-votoropin-cfa-808ba43a" class="editorial-link" rel="me noopener">LinkedIn</a>
          </p>
        </div>

      </div>
    </div>
  </section>

</Base>
