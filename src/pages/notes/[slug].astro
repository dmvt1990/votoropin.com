---
// src/pages/notes/[slug].astro
// Single note page.
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { t } from "../../i18n";

export async function getStaticPaths() {
  const collectionName = import.meta.env.PUBLIC_LANG === "ru" ? "notes-ru" : "notes";
  const notes = await getCollection(collectionName as "notes", ({ data }) => !data.draft);
  return notes.map((n) => ({ params: { slug: n.slug }, props: { entry: n } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Base title={entry.data.title} description={entry.data.summary}>
  <article class="container-narrow pt-20 pb-20">
    <div class="font-mono text-[11px] tracking-wide text-ink-mute mb-4">
      <a href="/notes" class="text-ink-mute no-underline hover:text-accent">{t.noteDetail.backLink}</a>
    </div>
    <div class="font-mono text-[11px] tracking-wider2 uppercase text-accent mb-4">
      {entry.data.tag}
    </div>
    <h1 class="display font-normal text-[40px] sm:text-[52px] leading-[1.05] tracking-tightest m-0 mb-4">
      {entry.data.title}
    </h1>
    <div class="font-mono text-[12px] text-ink-mute mb-10">
      {new Date(entry.data.date).toLocaleDateString(t.dateLocale, { year: "numeric", month: "long", day: "2-digit" })}
      &nbsp;·&nbsp; {entry.data.readMinutes} {t.noteDetail.minRead}
    </div>

    <div class="prose prose-stone max-w-none
                prose-headings:font-display prose-headings:font-normal prose-headings:tracking-tight
                prose-h2:text-[28px] prose-h2:mt-20 prose-h2:mb-6
                prose-h3:text-[20px]
                prose-p:text-[17px] prose-p:leading-[1.7] prose-p:text-ink-soft prose-p:mb-[1.5em]
                prose-strong:text-ink prose-strong:font-medium
                prose-a:text-accent prose-a:no-underline hover:prose-a:underline
                prose-blockquote:border-l-accent prose-blockquote:text-ink prose-blockquote:not-italic prose-blockquote:font-mono prose-blockquote:text-[14px]
                prose-li:text-ink-soft prose-li:text-[17px]">
      <Content />
    </div>
  </article>
</Base>
