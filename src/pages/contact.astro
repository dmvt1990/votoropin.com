---
// src/pages/contact.astro
import Base from "../layouts/Base.astro";
---

<Base
  title="Contact"
  description="Get in touch — research, portfolio mandates, index construction."
>
  <section class="container-narrow pt-32 pb-32 text-center">
    <h1 class="display font-light text-[44px] sm:text-[64px] leading-[1.05] tracking-tightest m-0 mb-8">
      Open to <em>conversations</em> —<br>
      research, portfolio mandates,<br>
      index licensing.
    </h1>

    <a
      href="mailto:hello@votoropin.com"
      class="display italic text-[26px] sm:text-[32px] text-accent no-underline border-b border-accent pb-1 inline-block"
    >
      d@votoropin.com
    </a>

    <div class="mt-12 flex flex-wrap gap-8 justify-center text-[14px]">
      <a href="www.linkedin.com/in/dmitrii-votoropin-cfa-808ba43a" rel="me noopener" class="text-ink-soft no-underline border-b border-rule pb-1 hover:text-accent hover:border-accent">LinkedIn</a>
      <a href="https://t.me/dmvtr" rel="me noopener" class="text-ink-soft no-underline border-b border-rule pb-1 hover:text-accent hover:border-accent">Telegram</a>
      <a href="/downloads/votoropin-cv.pdf" download class="text-ink-soft no-underline border-b border-rule pb-1 hover:text-accent hover:border-accent">Download CV (PDF)</a>
    </div>

    <p class="mt-16 text-ink-mute text-[13px] max-w-[420px] mx-auto">
      Replies typically within 48 hours. For research and licensing
      enquiries, please include the index or topic in the subject line.
    </p>
  </section>
</Base>
