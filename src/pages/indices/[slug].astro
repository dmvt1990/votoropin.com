---
// src/pages/indices/[slug].astro
// Dynamic page that renders a detail page for each MDX file in
// src/content/indices/. URLs: /indices/rhix, /indices/ritix.
//
// The MDX file now contains a short description (not a full methodology
// document). A disclaimer block is shown on every index page.

import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import IndexLevelChart from "../../components/IndexLevelChart.astro";
import ConstituentsTable from "../../components/ConstituentsTable.astro";
import Ribbon from "../../components/Ribbon.astro";

import { RHIX_CONSTITUENTS, RHIX_AS_OF } from "../../data/rhix-constituents";
import { RITIX_CONSTITUENTS, RITIX_AS_OF, RITIX_PERFORMANCE_2025 } from "../../data/ritix-constituents";
import { RHIX_SERIES, RITIX_SERIES, latestLevel } from "../../data/timeseries";

export async function getStaticPaths() {
  const indices = await getCollection("indices");
  return indices.map((i) => ({ params: { slug: i.slug }, props: { entry: i } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const isRhix = entry.slug === "rhix";
const isRitix = entry.slug === "ritix";

const series  = isRhix ? RHIX_SERIES : RITIX_SERIES;
const consts  = isRhix ? RHIX_CONSTITUENTS : RITIX_CONSTITUENTS;
const asOf    = isRhix ? RHIX_AS_OF : RITIX_AS_OF;
const showShares = isRhix;

const latest  = latestLevel(series);
const ytdPct  = ((latest.level / entry.data.baseValue - 1) * 100);
const ytdStr  = `${ytdPct >= 0 ? '+' : ''}${ytdPct.toFixed(2)}%`;

const ribbonCells = [
  { k: "Current Level", v: latest.level.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) },
  {
    k: isRitix ? "2025 Return" : "Period Return",
    v: isRitix ? `${RITIX_PERFORMANCE_2025.totalReturnPct.toFixed(2)}%` : ytdStr,
    tone: ((isRitix ? RITIX_PERFORMANCE_2025.totalReturnPct : ytdPct) >= 0 ? "positive" : "negative") as "positive" | "negative",
  },
  { k: "Constituents", v: String(consts.length) },
  { k: "Inception", v: entry.data.inceptionDate },
];

// ── Placeholder rebalancing history ────────────────────────────
// Replace with real entries as you actually rebalance the prototype.
const rebalanceHistory = isRhix
  ? [
      { date: entry.data.versionDate, note: "Latest review — current composition published." },
      { date: entry.data.inceptionDate, note: "Inception — initial composition fixed; base value 1,000." },
    ]
  : [
      { date: entry.data.versionDate, note: "Latest quarterly review — current composition published." },
      { date: entry.data.inceptionDate, note: "Inception — initial composition fixed; base value 1,000." },
    ];
---

<Base title={entry.data.name} description={entry.data.tagline}>

  <!-- ── HEADER ───────────────────────────────────────────────── -->
  <section class="container-wide pt-20 pb-12">
    <div class="text-[12px] text-ink-mute tracking-wide mb-8">
      <a href="/indices" class="text-ink-mute no-underline hover:text-accent">Research prototypes</a>
      <span class="mx-2">/</span>
      <span>{entry.data.name}</span>
    </div>
    <div class="font-mono text-[14px] tracking-wider2 text-accent mb-4">
      {entry.data.ticker}
    </div>
    <h1 class="display font-light text-[48px] sm:text-[68px] leading-[1.0] tracking-tightest m-0 mb-3">
      {entry.data.name}
    </h1>
    <p class="display italic text-[22px] text-ink-soft m-0 mb-14">
      {entry.data.ticker} · Personal research prototype · Inception {entry.data.inceptionDate}
    </p>

    <Ribbon cells={ribbonCells} />

    <IndexLevelChart
      id={`${entry.data.ticker.toLowerCase()}-big-chart`}
      data={series}
      label="Index Level — since inception"
      color={isRhix ? "#6B1F2E" : "#3D3D3A"}
    />

    <ConstituentsTable constituents={consts} asOf={asOf} showShares={showShares} />
  </section>

  <!-- ── DESCRIPTION (from MDX) ───────────────────────────────── -->
  <section class="bg-bg-sunken border-t border-rule">
    <div class="container-narrow py-20">
      <div class="section-label">Description</div>
      <article class="prose prose-stone max-w-none
                      prose-headings:font-display prose-headings:font-normal prose-headings:tracking-tight
                      prose-h2:text-[28px] prose-h2:mt-12 prose-h2:mb-5
                      prose-h3:text-[20px]
                      prose-p:text-[16px] prose-p:leading-relaxed prose-p:text-ink-soft
                      prose-strong:text-ink prose-strong:font-medium
                      prose-a:text-accent prose-a:no-underline hover:prose-a:underline
                      prose-li:text-ink-soft">
        <Content />
      </article>
    </div>
  </section>

  <!-- ── REBALANCING HISTORY ──────────────────────────────────── -->
  <section class="border-t border-rule">
    <div class="container-narrow py-20">
      <div class="section-label">Rebalancing history</div>
      <h2 class="display font-normal text-[28px] tracking-tight m-0 mb-8">
        Changes to constituents and weights, most recent first.
      </h2>
      <ul class="list-none p-0 m-0 border-t border-rule">
        {rebalanceHistory.map((r) => (
          <li class="grid grid-cols-[120px_1fr] gap-6 py-4 border-b border-rule items-baseline">
            <span class="font-mono text-[12px] text-accent tracking-wide">{r.date}</span>
            <span class="text-[15px] text-ink-soft leading-relaxed">{r.note}</span>
          </li>
        ))}
      </ul>
      <p class="mt-6 text-[13px] text-ink-mute italic">
        This is a placeholder log. As real rebalancings occur, they will
        be listed here with the date, the change to the constituent set,
        and a brief rationale.
      </p>
    </div>
  </section>

  <!-- ── DISCLAIMER ───────────────────────────────────────────── -->
  <section class="border-t border-rule">
    <div class="container-narrow py-16">
      <div class="bg-bg-sunken border-l-2 border-accent p-6">
        <div class="font-sans text-[11px] uppercase tracking-[0.18em] text-accent font-medium mb-3">
          Disclaimer
        </div>
        <p class="text-[14px] leading-relaxed text-ink-soft m-0">
          {entry.data.name} ({entry.data.ticker}) is a personal research
          prototype maintained by the author in his personal capacity. It
          is <strong class="text-ink">not</strong> an investment product,
          <strong class="text-ink">not</strong> a regulated benchmark
          under IOSCO, ESMA, or any other framework, and is
          <strong class="text-ink">not</strong> affiliated with, sponsored by,
          or endorsed by any current or former employer of the author. All
          constituent weights, index levels, and historical data are
          published for research and educational purposes only. Nothing on
          this page constitutes investment advice, a solicitation, or a
          recommendation to buy or sell any security.
        </p>
      </div>
    </div>
  </section>

</Base>
