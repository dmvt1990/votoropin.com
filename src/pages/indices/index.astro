---
// src/pages/indices/index.astro
// Indices overview page — personal research prototypes, RHIX and RITIX.
// Includes a disclaimer at the top so the framing is unmistakable.
import Base from "../../layouts/Base.astro";
import MiniChart from "../../components/MiniChart.astro";
import { RHIX_SERIES, RITIX_SERIES, latestLevel } from "../../data/timeseries";
import { t } from "../../i18n";

const rhix = latestLevel(RHIX_SERIES);
const ritix = latestLevel(RITIX_SERIES);

const rhixYtd = ((rhix.level / 1000 - 1) * 100).toFixed(2);
const ritixYtd = ((ritix.level / 1000 - 1) * 100).toFixed(2);
---

<Base
  title={t.indicesOverview.pageTitle}
  description={t.indicesOverview.pageDescription}
>

  <!-- ── HEADER ───────────────────────────────────────────────── -->
  <section class="container-wide pt-32 pb-12">
    <div class="text-[12px] uppercase tracking-[0.18em] text-ink-mute mb-8">
      {t.indicesOverview.eyebrow}
    </div>
    <h1 class="display font-light text-display-lg m-0 mb-9 max-w-[920px]">
      {t.indicesOverview.h1part1}<em>{t.indicesOverview.h1em}</em>{t.indicesOverview.h1part2}
    </h1>
    <p class="text-[18px] leading-relaxed max-w-[760px] text-ink-soft m-0">
      {t.indicesOverview.intro}
    </p>
  </section>

  <!-- ── DISCLAIMER ───────────────────────────────────────────── -->
  <section class="container-wide pb-12">
    <div class="bg-bg-sunken border-l-2 border-accent p-6 max-w-[920px]">
      <div class="font-sans text-[11px] uppercase tracking-[0.18em] text-accent font-medium mb-3">
        {t.indicesOverview.disclaimer.label}
      </div>
      <p class="text-[14px] leading-relaxed text-ink-soft m-0">
        {t.indicesOverview.disclaimer.text}
      </p>
    </div>
  </section>

  <!-- ── INDEX CARDS ──────────────────────────────────────────── -->
  <section class="container-wide pb-24">

    <!-- RITIX card -->
    <div class="grid md:grid-cols-2 gap-12 items-center py-14 border-t border-rule">
      <div>
        <div class="font-mono text-[14px] tracking-wider2 text-accent mb-4">
          {t.home.research.ritix.ticker}
        </div>
        <h2 class="display font-normal text-[36px] leading-[1.05] tracking-tighter m-0 mb-5">
          {t.home.research.ritix.h3}
        </h2>
        <p class="text-ink-soft text-[15px] leading-relaxed mb-7">
          {t.home.research.ritix.desc}
        </p>
        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-rule">
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">{t.home.research.ritix.constituentsLabel}</div>
            <div class="font-display text-[24px] tracking-tight">10</div>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">{t.home.research.ritix.sinceInceptionLabel}</div>
            <div class={`font-display text-[24px] tracking-tight ${parseFloat(ritixYtd) >= 0 ? 'text-positive' : 'text-negative'}`}>
              {parseFloat(ritixYtd) >= 0 ? '+' : ''}{ritixYtd}%
            </div>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">{t.home.research.ritix.rebalanceLabel}</div>
            <div class="font-display text-[24px] tracking-tight">{t.home.research.ritix.rebalanceValue}</div>
          </div>
        </div>
        <p class="mt-7">
          <a href="/indices/ritix" class="editorial-link text-[14px]">
            {t.home.research.ritix.link}
          </a>
        </p>
      </div>
      <MiniChart id="ritix-overview-chart" data={RITIX_SERIES} color="#3D3D3A" />
    </div>

    <!-- RHIX card -->
    <div class="grid md:grid-cols-2 gap-12 items-center py-14 border-t border-b border-rule">
      <div>
        <div class="font-mono text-[14px] tracking-wider2 text-accent mb-4">
          {t.home.research.rhix.ticker}
        </div>
        <h2 class="display font-normal text-[36px] leading-[1.05] tracking-tighter m-0 mb-5">
          {t.home.research.rhix.h3}
        </h2>
        <p class="text-ink-soft text-[15px] leading-relaxed mb-7">
          {t.home.research.rhix.desc}
        </p>
        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-rule">
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">{t.home.research.rhix.constituentsLabel}</div>
            <div class="font-display text-[24px] tracking-tight">5</div>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">{t.home.research.rhix.ytdLabel}</div>
            <div class={`font-display text-[24px] tracking-tight ${parseFloat(rhixYtd) >= 0 ? 'text-positive' : 'text-negative'}`}>
              {parseFloat(rhixYtd) >= 0 ? '+' : ''}{rhixYtd}%
            </div>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">{t.home.research.rhix.rebalanceLabel}</div>
            <div class="font-display text-[24px] tracking-tight">{t.home.research.rhix.rebalanceValue}</div>
          </div>
        </div>
        <p class="mt-7">
          <a href="/indices/rhix" class="editorial-link text-[14px]">
            {t.home.research.rhix.link}
          </a>
        </p>
      </div>
      <MiniChart id="rhix-overview-chart" data={RHIX_SERIES} color="#6B1F2E" />
    </div>
  </section>

</Base>
