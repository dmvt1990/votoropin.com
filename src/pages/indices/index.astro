---
// src/pages/indices/index.astro
// Indices overview page — lists RHIX and RITIX with mini charts.
// Each card links to /indices/rhix or /indices/ritix for the full page.
import Base from "../../layouts/Base.astro";
import MiniChart from "../../components/MiniChart.astro";
import { RHIX_SERIES, RITIX_SERIES, latestLevel } from "../../data/timeseries";

const rhix = latestLevel(RHIX_SERIES);
const ritix = latestLevel(RITIX_SERIES);

const rhixYtd = ((rhix.level / 1000 - 1) * 100).toFixed(2);
const ritixYtd = ((ritix.level / 1000 - 1) * 100).toFixed(2);
---

<Base
  title="Indices — RHIX, RITIX"
  description="Two rules-based equity indices published openly with full methodology: RHIX (Russian Healthcare) and RITIX (Russia IT)."
>

  <!-- ── HEADER ───────────────────────────────────────────────── -->
  <section class="container-wide pt-32 pb-12">
    <div class="text-[12px] uppercase tracking-[0.18em] text-ink-mute mb-8">
      Indices
    </div>
    <h1 class="display font-light text-display-lg m-0 mb-9 max-w-[900px]">
      Two rules-based <em>equity benchmarks</em>, published openly with full methodology.
    </h1>
    <p class="text-[18px] leading-relaxed max-w-[760px] text-ink-soft mb-0">
      Both indices cover under-followed segments of the Moscow Exchange and are
      maintained on fixed rebalance schedules. Methodology documents, current
      constituents, and level histories are all published on this site.
    </p>
  </section>

  <!-- ── INDEX CARDS ──────────────────────────────────────────── -->
  <section class="container-wide pb-24">

    <!-- RHIX card -->
    <div class="grid md:grid-cols-2 gap-12 items-center py-14 border-t border-rule">
      <div>
        <div class="font-mono text-[14px] tracking-wider2 text-accent mb-4">
          RHIX · Russian Healthcare Index
        </div>
        <h2 class="display font-normal text-[38px] leading-[1.05] tracking-tighter m-0 mb-5">
          <em>Healthcare</em> &amp; biotech, MOEX-listed.
        </h2>
        <p class="text-ink-soft text-[15px] leading-relaxed mb-7">
          Free-float market-cap weighted index of five core healthcare,
          pharmaceutical, and biotechnology issuers on the Moscow Exchange.
          Constructed under GICS Sector 35 with a related-company rule to
          prevent hidden concentration.
        </p>
        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-rule">
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">Constituents</div>
            <div class="font-display text-[24px] tracking-tight">5</div>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">YTD</div>
            <div class={`font-display text-[24px] tracking-tight ${parseFloat(rhixYtd) >= 0 ? 'text-positive' : 'text-negative'}`}>
              {parseFloat(rhixYtd) >= 0 ? '+' : ''}{rhixYtd}%
            </div>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">Rebalance</div>
            <div class="font-display text-[24px] tracking-tight">Semi-ann.</div>
          </div>
        </div>
        <p class="mt-7">
          <a href="/indices/rhix" class="editorial-link text-[14px]">
            Methodology &amp; live levels →
          </a>
        </p>
      </div>
      <MiniChart id="rhix-overview-chart" data={RHIX_SERIES} color="#6B1F2E" />
    </div>

    <!-- RITIX card -->
    <div class="grid md:grid-cols-2 gap-12 items-center py-14 border-t border-b border-rule">
      <div>
        <div class="font-mono text-[14px] tracking-wider2 text-accent mb-4">
          RITIX · Russia IT Index
        </div>
        <h2 class="display font-normal text-[38px] leading-[1.05] tracking-tighter m-0 mb-5">
          <em>Russian technology</em>, square-root weighted.
        </h2>
        <p class="text-ink-soft text-[15px] leading-relaxed mb-7">
          Square-root free-float-adjusted market-cap weighted index of ten
          Russian IT issuers on the Moscow Exchange. Quarterly rebalancing.
          Designed as a diversified benchmark across the domestic technology
          stack.
        </p>
        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-rule">
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">Constituents</div>
            <div class="font-display text-[24px] tracking-tight">10</div>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">2025 Return</div>
            <div class="font-display text-[24px] tracking-tight text-negative">−27.31%</div>
          </div>
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] text-ink-mute mb-1.5">Volatility</div>
            <div class="font-display text-[24px] tracking-tight">23.7%</div>
          </div>
        </div>
        <p class="mt-7">
          <a href="/indices/ritix" class="editorial-link text-[14px]">
            Methodology &amp; performance →
          </a>
        </p>
      </div>
      <MiniChart id="ritix-overview-chart" data={RITIX_SERIES} color="#3D3D3A" />
    </div>
  </section>

</Base>
