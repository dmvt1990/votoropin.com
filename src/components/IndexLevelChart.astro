---
// src/components/IndexLevelChart.astro
// Full-size historical chart for index detail pages.
//
// Shows the main index series with an area fill, plus optional benchmark
// series as thinner dashed lines. All visible series are rebased to 1000
// at the start of the selected time period so relative performance is
// immediately comparable regardless of which period is chosen.

export interface BenchmarkSeries {
  ticker: string;
  data: [string, number][];
  color: string;
}

export interface Props {
  id: string;
  data: [string, number][];       // main index series
  label: string;
  color?: string;
  benchmarks?: BenchmarkSeries[];
  /** Show 3Y / 5Y period buttons (longer-history indices only) */
  longPeriods?: boolean;
}

import { t } from "../i18n";
const { id, data, label, color = "#6B1F2E", benchmarks = [], longPeriods = false } = Astro.props;
const dataJSON       = JSON.stringify(data);
const benchmarksJSON = JSON.stringify(benchmarks);
---

<div class="bg-bg border border-rule p-6 mb-8">
  <!-- Header row: title + period buttons -->
  <div class="flex justify-between items-baseline pb-4 mb-2 border-b border-rule">
    <h4 class="font-display text-[18px] font-medium m-0">{label}</h4>
    <div class="flex gap-1 font-mono text-[11px]" data-periods data-target={id}>
      <button data-range="1M"  class="px-2.5 py-1 text-ink-mute hover:text-ink">{t.chart.periods["1M"]}</button>
      <button data-range="3M"  class="px-2.5 py-1 text-ink-mute hover:text-ink">{t.chart.periods["3M"]}</button>
      <button data-range="YTD" class="px-2.5 py-1 text-ink-mute hover:text-ink">{t.chart.periods.ytd}</button>
      <button data-range="1Y"  class="px-2.5 py-1 bg-ink text-bg" aria-pressed="true">{t.chart.periods["1Y"]}</button>
      {longPeriods && <button data-range="3Y" class="px-2.5 py-1 text-ink-mute hover:text-ink">{t.chart.periods["3Y"]}</button>}
      {longPeriods && <button data-range="5Y" class="px-2.5 py-1 text-ink-mute hover:text-ink">{t.chart.periods["5Y"]}</button>}
      <button data-range="ALL" class="px-2.5 py-1 text-ink-mute hover:text-ink">{t.chart.periods.all}</button>
    </div>
  </div>

  <!-- Legend row (only when benchmarks are present) -->
  {benchmarks.length > 0 && (
    <div class="flex gap-5 pt-2 pb-4 font-mono text-[11px] text-ink-mute">
      <span class="flex items-center gap-1.5">
        <span style={`display:inline-block;width:18px;border-top:2px solid ${color};`}></span>
        {id.split("-")[0].toUpperCase()}
      </span>
      {benchmarks.map((b) => (
        <span class="flex items-center gap-1.5">
          <span style={`display:inline-block;width:18px;border-top:1.5px dashed ${b.color};`}></span>
          {b.ticker}
        </span>
      ))}
    </div>
  )}

  <!-- Chart canvas -->
  <div
    id={id}
    style="width: 100%; height: 380px;"
    data-bigchart
    data-chart-data={dataJSON}
    data-chart-color={color}
    data-chart-benchmarks={benchmarksJSON}
    data-chart-locale={t.chart.locale}
  ></div>
</div>

<script>
  let echartsPromise: Promise<typeof import("echarts")> | null = null;
  const load = () => (echartsPromise ??= import("echarts"));

  type EChartsInst = Awaited<ReturnType<typeof load>>["init"] extends (...a: any) => infer R
    ? R
    : never;

  interface BenchmarkSeries {
    ticker: string;
    data: [string, number][];
    color: string;
  }

  // Stored full (unfiltered) data per chart id
  const fullMain       = new Map<string, [string, number][]>();
  const fullBenchmarks = new Map<string, BenchmarkSeries[]>();
  const charts         = new Map<string, EChartsInst>();

  // ── Helpers ────────────────────────────────────────────────────────────────

  /** Cut a series to only include points after (or on) the cutoff date string. */
  function sliceFrom(data: [string, number][], from: string): [string, number][] {
    return data.filter(([d]) => d >= from);
  }

  /**
   * Compute the date string that marks the start of the requested range,
   * measured back from the last point in the main series.
   */
  function rangeStart(main: [string, number][], range: string): string | null {
    if (range === "ALL" || main.length === 0) return null;
    const lastDate = new Date(main[main.length - 1][0]);
    const cutoff   = new Date(lastDate);
    switch (range) {
      case "1M":  cutoff.setMonth(cutoff.getMonth() - 1);          break;
      case "3M":  cutoff.setMonth(cutoff.getMonth() - 3);          break;
      case "1Y":  cutoff.setFullYear(cutoff.getFullYear() - 1);    break;
      case "3Y":  cutoff.setFullYear(cutoff.getFullYear() - 3);    break;
      case "5Y":  cutoff.setFullYear(cutoff.getFullYear() - 5);    break;
      case "YTD": cutoff.setFullYear(lastDate.getFullYear(), 0, 1); break;
      default:    return null;
    }
    return cutoff.toISOString().slice(0, 10);
  }

  /**
   * Rebase a series so its first point equals 1000.
   * Applied to each visible window independently so every period starts at 1000.
   */
  function rebase(data: [string, number][]): [string, number][] {
    if (data.length === 0) return [];
    const base = data[0][1];
    if (base === 0) return data;
    return data.map(([d, v]) => [d, (v / base) * 1000]);
  }

  /** Format a Unix-ms timestamp as DD.MM.YYYY (European format). */
  function fmtDate(ts: number): string {
    const d = new Date(ts);
    const day   = String(d.getUTCDate()).padStart(2, "0");
    const month = String(d.getUTCMonth() + 1).padStart(2, "0");
    const year  = d.getUTCFullYear();
    return `${day}.${month}.${year}`;
  }

  // ── Chart rendering ────────────────────────────────────────────────────────

  function applyRange(chartId: string, range: string) {
    const chart      = charts.get(chartId);
    const main       = fullMain.get(chartId) ?? [];
    const benchmarks = fullBenchmarks.get(chartId) ?? [];
    const el0        = document.getElementById(chartId) as HTMLElement;
    const color      = el0?.dataset.chartColor ?? "#6B1F2E";
    const chartLocale = el0?.dataset.chartLocale ?? "en";
    if (!chart) return;

    const from        = rangeStart(main, range);
    const mainSlice   = from ? sliceFrom(main, from) : main;
    const mainRebased = rebase(mainSlice);

    // Update the linked period-return figure in the ribbon, if present.
    const retEl = document.querySelector(`[data-period-return][data-target="${chartId}"]`);
    if (retEl) {
      const r = mainRebased.length ? mainRebased[mainRebased.length - 1][1] / 1000 - 1 : 0;
      retEl.textContent = `${r >= 0 ? "+" : ""}${(r * 100).toFixed(2)}%`;
      retEl.classList.toggle("text-positive", r >= 0);
      retEl.classList.toggle("text-negative", r < 0);
    }

    // Each benchmark is also sliced to the same date window, then rebased
    // independently (so each line starts at 1000 on the first visible date).
    const benchSeries = benchmarks.map((b) => {
      const sliced  = from ? sliceFrom(b.data, from) : b.data;
      const rebased = rebase(sliced);
      return { ticker: b.ticker, color: b.color, data: rebased };
    });

    chart.setOption({
      grid: { left: 60, right: 24, top: 12, bottom: 36 },

      xAxis: {
        type: "time",
        boundaryGap: false,
        axisLine: { lineStyle: { color: "#D9D2C0" } },
        axisTick: { show: false },
        splitLine: { show: false },
        axisLabel: {
          color: "#8A857C",
          fontFamily: "'Inter Tight', sans-serif",
          fontSize: 11,
          // Show "Jan YYYY" in January, otherwise abbreviated month name
          formatter: (value: number) => {
            const d = new Date(value);
            const monthShort = d.toLocaleString(chartLocale, { month: "short" });
            if (d.getMonth() === 0) {
              return `${monthShort} ${d.getFullYear()}`;
            }
            return monthShort;
          },
        },
      },

      yAxis: {
        type: "value",
        scale: true,
        axisLine: { show: false },
        axisTick: { show: false },
        splitLine: { lineStyle: { color: "#D9D2C0", type: "dashed" } },
        axisLabel: {
          color: "#8A857C",
          fontFamily: "'Inter Tight', sans-serif",
          fontSize: 11,
          formatter: (v: number) =>
            v.toLocaleString("en", { maximumFractionDigits: 0 }),
        },
      },

      tooltip: {
        trigger: "axis",
        backgroundColor: "#1A1A1A",
        borderColor: "#1A1A1A",
        padding: [10, 14],
        textStyle: {
          color: "#FAF7F0",
          fontFamily: "'Inter Tight', sans-serif",
          fontSize: 12,
        },
        formatter: (params: any[]) => {
          const dateStr = fmtDate(params[0].axisValue);
          const rows = params
            .map((p: any) => {
              const val = (p.data as [string, number])[1];
              const formatted = val.toLocaleString("en", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
              });
              const isMain = p.seriesIndex === 0;
              return `
                <div style="display:flex;justify-content:space-between;
                            gap:20px;margin-top:4px;opacity:${isMain ? 1 : 0.65}">
                  <span style="color:#8A857C">${p.seriesName}</span>
                  <span style="font-variant-numeric:tabular-nums">${formatted}</span>
                </div>`;
            })
            .join("");
          return `
            <div style="font-family:'Inter Tight',sans-serif;min-width:170px;">
              <div style="color:#8A857C;font-size:10px;letter-spacing:0.12em;
                          text-transform:uppercase;margin-bottom:2px;">${dateStr}</div>
              ${rows}
            </div>`;
        },
      },

      series: [
        // ── Main index series ──────────────────────────────────────────────
        {
          name: chartId.split("-")[0].toUpperCase(),
          type: "line",
          data: mainRebased,
          showSymbol: false,
          smooth: false,
          lineStyle: { color, width: 2 },
        },
        // ── Benchmark series (dashed, no area fill) ────────────────────────
        ...benchSeries.map((b) => ({
          name: b.ticker,
          type: "line",
          data: b.data,
          showSymbol: false,
          smooth: false,
          lineStyle: { color: b.color, width: 1.5, type: "dashed" as const },
        })),
      ],

      animation: false,
    });
  }

  // ── Mount a chart element ──────────────────────────────────────────────────

  async function mount(el: HTMLElement) {
    const echarts    = await load();
    const main       = JSON.parse(el.dataset.chartData       || "[]") as [string, number][];
    const benchmarks = JSON.parse(el.dataset.chartBenchmarks || "[]") as BenchmarkSeries[];

    fullMain.set(el.id, main);
    fullBenchmarks.set(el.id, benchmarks);

    const chart = echarts.init(el);
    charts.set(el.id, chart);

    applyRange(el.id, "1Y");   // default period
    new ResizeObserver(() => chart.resize()).observe(el);

    // Wire up the period-selector buttons for this chart
    document
      .querySelectorAll<HTMLElement>(`[data-periods][data-target="${el.id}"]`)
      .forEach((bar) => {
        bar.querySelectorAll<HTMLButtonElement>("button").forEach((btn) => {
          btn.addEventListener("click", () => {
            bar.querySelectorAll("button").forEach((b) => {
              b.classList.remove("bg-ink", "text-bg");
              b.classList.add("text-ink-mute");
              b.removeAttribute("aria-pressed");
            });
            btn.classList.add("bg-ink", "text-bg");
            btn.classList.remove("text-ink-mute");
            btn.setAttribute("aria-pressed", "true");
            applyRange(el.id, btn.dataset.range!);
          });
        });
      });
  }

  // ── Initialise on page load (lazy via IntersectionObserver) ───────────────

  function init() {
    const els = document.querySelectorAll<HTMLElement>("[data-bigchart]");
    if (!els.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const el = e.target as HTMLElement;
          if ((el as any)._mounted) continue;
          (el as any)._mounted = true;
          mount(el);
          io.unobserve(el);
        }
      },
      { rootMargin: "200px" }
    );
    els.forEach((el) => io.observe(el));
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
