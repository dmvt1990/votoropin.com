---
// src/components/IndexLevelChart.astro
// Full-size historical chart used on index detail pages.
// Has a period selector that filters the displayed range.

export interface Props {
  id: string;
  data: [string, number][];
  label: string;
  color?: string;
}

const { id, data, label, color = "#6B1F2E" } = Astro.props;
const dataJSON = JSON.stringify(data);
---

<div class="bg-bg border border-rule p-6 mb-8">
  <div class="flex justify-between items-baseline pb-4 mb-5 border-b border-rule">
    <h4 class="font-display text-[18px] font-medium m-0">{label}</h4>
    <div class="flex gap-1 font-mono text-[11px]" data-periods data-target={id}>
      <button data-range="1M"  class="px-2.5 py-1 text-ink-mute hover:text-ink">1M</button>
      <button data-range="3M"  class="px-2.5 py-1 text-ink-mute hover:text-ink">3M</button>
      <button data-range="YTD" class="px-2.5 py-1 text-ink-mute hover:text-ink">YTD</button>
      <button data-range="1Y"  class="px-2.5 py-1 bg-ink text-bg" aria-pressed="true">1Y</button>
      <button data-range="ALL" class="px-2.5 py-1 text-ink-mute hover:text-ink">All</button>
    </div>
  </div>
  <div
    id={id}
    style="width: 100%; height: 380px;"
    data-bigchart
    data-chart-data={dataJSON}
    data-chart-color={color}
  ></div>
</div>

<script>
  let echartsPromise: Promise<typeof import("echarts")> | null = null;
  const load = () => echartsPromise ??= import("echarts");

  type EChartsType = Awaited<ReturnType<typeof load>>["init"] extends (...a: any) => infer R ? R : never;
  const charts = new Map<string, EChartsType>();
  const fullData = new Map<string, [string, number][]>();

  function filterRange(data: [string, number][], range: string): [string, number][] {
    if (range === "ALL") return data;
    const last = new Date(data[data.length - 1][0]);
    const cutoff = new Date(last);

    switch (range) {
      case "1M": cutoff.setMonth(cutoff.getMonth() - 1); break;
      case "3M": cutoff.setMonth(cutoff.getMonth() - 3); break;
      case "1Y": cutoff.setFullYear(cutoff.getFullYear() - 1); break;
      case "YTD": cutoff.setFullYear(last.getFullYear(), 0, 1); break;
      default: return data;
    }
    return data.filter(([d]) => new Date(d) >= cutoff);
  }

  function applyData(chart: any, data: [string, number][], color: string) {
    chart.setOption({
      grid: { left: 56, right: 24, top: 20, bottom: 36 },
      xAxis: {
        type: "time",
        axisLine: { lineStyle: { color: "#D9D2C0" } },
        axisTick: { show: false },
        axisLabel: { color: "#8A857C", fontFamily: "'Inter Tight', sans-serif", fontSize: 11 },
        splitLine: { show: false },
      },
      yAxis: {
        type: "value",
        scale: true,
        axisLine: { show: false },
        axisTick: { show: false },
        axisLabel: { color: "#8A857C", fontFamily: "'Inter Tight', sans-serif", fontSize: 11 },
        splitLine: { lineStyle: { color: "#D9D2C0", type: "dashed" } },
      },
      tooltip: {
        trigger: "axis",
        backgroundColor: "#1A1A1A",
        borderColor: "#1A1A1A",
        textStyle: { color: "#FAF7F0", fontFamily: "'Inter Tight', sans-serif", fontSize: 12 },
        formatter: (params: any) => {
          const p = params[0];
          return `<div style="font-family:'Inter Tight',sans-serif;">
            <div style="color:#8A857C;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:4px;">${String(p.axisValue).slice(0,10)}</div>
            <div style="font-size:18px;font-variant-numeric:tabular-nums;">${p.data[1].toLocaleString()}</div>
          </div>`;
        },
      },
      series: [{
        type: "line",
        data,
        showSymbol: false,
        smooth: 0.15,
        lineStyle: { color, width: 2 },
        areaStyle: {
          color: {
            type: "linear", x: 0, y: 0, x2: 0, y2: 1,
            colorStops: [
              { offset: 0, color: color + "30" },
              { offset: 1, color: color + "00" },
            ],
          },
        },
      }],
      animation: false,
    });
  }

  async function mount(el: HTMLElement) {
    const echarts = await load();
    const data = JSON.parse(el.dataset.chartData || "[]");
    const color = el.dataset.chartColor || "#6B1F2E";
    const chart = echarts.init(el);
    charts.set(el.id, chart);
    fullData.set(el.id, data);
    applyData(chart, filterRange(data, "1Y"), color);
    new ResizeObserver(() => chart.resize()).observe(el);

    // Wire up the period selector for this chart
    document.querySelectorAll<HTMLElement>(`[data-periods][data-target="${el.id}"]`).forEach((bar) => {
      bar.querySelectorAll<HTMLButtonElement>("button").forEach((btn) => {
        btn.addEventListener("click", () => {
          bar.querySelectorAll("button").forEach((b) => {
            b.classList.remove("bg-ink", "text-bg");
            b.classList.add("text-ink-mute");
            b.removeAttribute("aria-pressed");
          });
          btn.classList.add("bg-ink", "text-bg");
          btn.classList.remove("text-ink-mute");
          btn.setAttribute("aria-pressed", "true");
          const range = btn.dataset.range!;
          applyData(chart, filterRange(data, range), color);
        });
      });
    });
  }

  function init() {
    const els = document.querySelectorAll<HTMLElement>("[data-bigchart]");
    if (!els.length) return;
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          const el = e.target as HTMLElement;
          if ((el as any)._mounted) continue;
          (el as any)._mounted = true;
          mount(el);
          io.unobserve(el);
        }
      }
    }, { rootMargin: "200px" });
    els.forEach((el) => io.observe(el));
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
