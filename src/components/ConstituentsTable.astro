---
// src/components/ConstituentsTable.astro
// Renders the constituents of an index with sortable columns
// (server-rendered, no JS sort for now — can add later if needed).

import type { Constituent } from "../data/rhix-constituents";
import { t } from "../i18n";

export interface Props {
  constituents: Constituent[];
  asOf: string;
  /** Show shares column (some indices don't track it) */
  showShares?: boolean;
  /** Show free-float column (some indices don't track it) */
  showFreeFloat?: boolean;
}

const { constituents, asOf, showShares = true, showFreeFloat = true } = Astro.props;
const ru = import.meta.env.PUBLIC_LANG === "ru";
// asOf is already a formatted date string from the page; display as-is.
const formattedAsOf = asOf;
---

<div>
  <h3 class="font-display text-[28px] font-normal m-0 mb-6">
    {t.constituents.headingPrefix} {formattedAsOf}
  </h3>
  <div class="overflow-x-auto bg-bg border border-rule">
    <table class="w-full border-collapse">
      <thead>
        <tr class="bg-bg-sunken">
          <th class="text-left px-5 py-4 text-[11px] uppercase tracking-wider2 text-ink-mute font-medium border-b border-rule">{t.constituents.th.ticker}</th>
          <th class="text-left px-5 py-4 text-[11px] uppercase tracking-wider2 text-ink-mute font-medium border-b border-rule">{t.constituents.th.company}</th>
          <th class="text-left px-5 py-4 text-[11px] uppercase tracking-wider2 text-ink-mute font-medium border-b border-rule">{t.constituents.th.subIndustry}</th>
          {showShares && (
            <th class="text-right px-5 py-4 text-[11px] uppercase tracking-wider2 text-ink-mute font-medium border-b border-rule">{t.constituents.th.sharesM}</th>
          )}
          {showFreeFloat && (
            <th class="text-center px-5 py-4 text-[11px] uppercase tracking-wider2 text-ink-mute font-medium border-b border-rule">{t.constituents.th.freeFloat}</th>
          )}
          <th class="text-center px-5 py-4 text-[11px] uppercase tracking-wider2 text-ink-mute font-medium border-b border-rule">{t.constituents.th.weight}</th>
        </tr>
      </thead>
      <tbody>
        {
          constituents.map((c) => (
            <tr class="border-b border-rule last:border-b-0">
              <td class="px-5 py-4 font-mono text-[14px] text-accent tracking-wide">{c.ticker}</td>
              <td class="px-5 py-4 font-display text-[16px]">{ru && c.nameRu ? c.nameRu : c.name}</td>
              <td class="px-5 py-4 text-[13px] text-ink-mute">{ru && c.subIndustryRu ? c.subIndustryRu : c.subIndustry}</td>
              {showShares && (
                <td class="px-5 py-4 font-mono text-[14px] text-right numeric">
                  {c.sharesMillions ? c.sharesMillions.toFixed(1) : "—"}
                </td>
              )}
              {showFreeFloat && (
                <td class="px-5 py-4 font-mono text-[14px] text-center numeric">{c.freeFloatPct}%</td>
              )}
              <td class="px-5 py-4 font-mono text-[14px] text-center numeric font-medium">{c.weightPct.toFixed(1)}%</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>
